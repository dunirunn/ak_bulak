<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>АК-БУЛАК · Водные ресурсы Казахстана</title>

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>

<!-- Chart.js for mini-charts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<style>
:root {
  --ocean: #0D4F8C;
  --emerald: #12856A;
  --amber: #D4860A;
  --coral: #C13B2A;
  --sky: #1A6FB5;
  --glass-bg: rgba(255,255,255,0.88);
  --glass-border: rgba(255,255,255,0.55);
  --glass-shadow: 0 8px 32px rgba(13,35,80,0.18), 0 1.5px 4px rgba(0,0,0,0.08);
  --blur: blur(18px);
  --panel-radius: 18px;
  --text-dark: #0F1B2D;
  --text-mid: #3A4D68;
  --text-soft: #6B7E9A;
  --status-good: #12856A;
  --status-warn: #D4860A;
  --status-bad: #C13B2A;
  --row-alt: rgba(13,79,140,0.035);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
  background: #0a1628;
  overflow: hidden;
  height: 100vh;
  width: 100vw;
  color: var(--text-dark);
}


#map {
  position: absolute; inset: 0;
  z-index: 1;
}

#header {
  position: absolute; top: 0; left: 0; right: 0;
  height: 58px;
  z-index: 100;
  background: rgba(10,22,40,0.75);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  display: flex; align-items: center; gap: 20px;
  padding: 0 20px;
}

.logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.logo-mark {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, #1A6FB5 0%, #12856A 100%);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}
.logo-text { color: #fff; }
.logo-text strong { display: block; font-size: 14px; font-weight: 700; letter-spacing: 0.08em; }
.logo-text span { display: block; font-size: 10px; color: rgba(255,255,255,0.5); letter-spacing: 0.04em; }

.header-stats {
  display: flex; gap: 2px; margin-left: auto;
}
.hstat {
  padding: 4px 14px;
  border-radius: 20px;
  background: rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.75);
  font-size: 12px;
  display: flex; align-items: center; gap: 6px;
  transition: background .2s;
  cursor: default;
}
.hstat:hover { background: rgba(255,255,255,0.1); }
.hstat strong { color: #fff; font-size: 15px; }
.hstat-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.hstat-dot.good { background: var(--emerald); }
.hstat-dot.warn { background: var(--amber); }
.hstat-dot.bad  { background: var(--coral); }

.btn-primary {
  padding: 8px 16px; border-radius: 22px;
  background: linear-gradient(135deg, #1A6FB5, #12856A);
  color: #fff; border: none; cursor: pointer;
  font-size: 13px; font-weight: 600;
  white-space: nowrap;
  transition: opacity .2s, transform .15s;
  box-shadow: 0 2px 12px rgba(26,111,181,0.35);
}
.btn-primary:hover { opacity: .88; transform: translateY(-1px); }
.btn-primary:active { transform: scale(0.97); }

.btn-outline {
  padding: 7px 14px; border-radius: 22px;
  background: transparent;
  color: rgba(255,255,255,0.8);
  border: 1px solid rgba(255,255,255,0.2); cursor: pointer;
  font-size: 13px; font-weight: 500;
  white-space: nowrap;
  transition: background .2s, border-color .2s;
}
.btn-outline:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.35); }

.nav-tabs {
  display: flex; gap: 2px; margin-left: 10px;
}
.nav-tab {
  padding: 6px 14px; border-radius: 16px;
  background: transparent; color: rgba(255,255,255,0.55);
  border: none; cursor: pointer; font-size: 13px;
  transition: background .2s, color .2s;
}
.nav-tab:hover { color: rgba(255,255,255,0.85); background: rgba(255,255,255,0.07); }
.nav-tab.active { background: rgba(255,255,255,0.12); color: #fff; font-weight: 600; }


#view-map { display: block; }
#view-science { display: none; }


#left-panel {
  position: absolute; top: 70px; left: 14px;
  width: 280px; z-index: 50;
  background: var(--glass-bg);
  backdrop-filter: var(--blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--panel-radius);
  box-shadow: var(--glass-shadow);
  overflow: hidden;
  max-height: calc(100vh - 84px);
  display: flex; flex-direction: column;
  transition: transform .4s cubic-bezier(.22,.87,.36,1);
}

.panel-header {
  padding: 14px 16px 10px;
  border-bottom: 1px solid rgba(13,79,140,0.1);
  display: flex; align-items: center; justify-content: space-between;
}
.panel-title { font-size: 13px; font-weight: 700; color: var(--text-dark); letter-spacing: 0.03em; }
.panel-badge {
  font-size: 10px; font-weight: 700; padding: 2px 7px;
  border-radius: 10px; background: rgba(26,111,181,0.12); color: var(--ocean);
}

.panel-scroll { overflow-y: auto; padding: 12px; flex: 1; }
.panel-scroll::-webkit-scrollbar { width: 4px; }
.panel-scroll::-webkit-scrollbar-track { background: transparent; }
.panel-scroll::-webkit-scrollbar-thumb { background: rgba(13,79,140,0.15); border-radius: 2px; }

.stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 14px; }
.stat-card {
  background: linear-gradient(135deg, rgba(26,111,181,0.07) 0%, rgba(18,133,106,0.05) 100%);
  border: 1px solid rgba(26,111,181,0.14);
  border-radius: 12px; padding: 10px;
  cursor: default;
}
.stat-card .label { font-size: 10px; color: var(--text-soft); font-weight: 500; line-height: 1.3; }
.stat-card .value { font-size: 22px; font-weight: 800; color: var(--ocean); line-height: 1.2; margin-top: 3px; }
.stat-card .subtext { font-size: 10px; color: var(--text-soft); margin-top: 1px; }

.filter-section { margin-bottom: 12px; }
.filter-label { font-size: 11px; font-weight: 700; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; display: block; }

.filter-select {
  width: 100%; padding: 8px 10px; border-radius: 10px;
  border: 1px solid rgba(13,79,140,0.18);
  background: rgba(255,255,255,0.9); color: var(--text-dark);
  font-size: 13px; outline: none; cursor: pointer;
  transition: border-color .2s;
}
.filter-select:focus { border-color: var(--sky); }

.checkbox-group { display: flex; flex-direction: column; gap: 5px; }
.check-item { display: flex; align-items: center; gap: 8px; cursor: pointer; padding: 5px 7px; border-radius: 8px; transition: background .15s; }
.check-item:hover { background: rgba(13,79,140,0.05); }
.check-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
.check-item input { margin: 0; cursor: pointer; accent-color: var(--sky); }
.check-item span { font-size: 12px; color: var(--text-mid); }

.slider-row { display: flex; align-items: center; gap: 8px; }
.slider-row input[type=range] { flex: 1; accent-color: var(--sky); height: 4px; cursor: pointer; }
.slider-val { font-size: 11px; font-weight: 700; color: var(--ocean); min-width: 24px; text-align: right; }


#right-panel {
  position: absolute; top: 70px; right: 14px;
  width: 300px; z-index: 50;
  background: var(--glass-bg);
  backdrop-filter: var(--blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--panel-radius);
  box-shadow: var(--glass-shadow);
  max-height: calc(100vh - 84px);
  display: flex; flex-direction: column;
  overflow: hidden;
  transition: transform .4s cubic-bezier(.22,.87,.36,1);
}

.passport-empty {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 30px 20px; text-align: center;
}
.passport-empty .icon { font-size: 40px; margin-bottom: 10px; opacity: 0.4; }
.passport-empty p { font-size: 13px; color: var(--text-soft); line-height: 1.6; }

.passport-content { flex: 1; overflow-y: auto; padding: 0; }
.passport-content::-webkit-scrollbar { width: 4px; }
.passport-content::-webkit-scrollbar-thumb { background: rgba(13,79,140,0.15); border-radius: 2px; }

.passport-photo {
  width: 100%; height: 140px; object-fit: cover;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.passport-photo-img { width: 100%; height: 140px; object-fit: cover; }
.passport-photo-placeholder {
  width: 100%; height: 140px;
  display: flex; align-items: center; justify-content: center;
  font-size: 50px; opacity: 0.3;
}

.passport-body { padding: 14px 16px; }
.passport-name { font-size: 16px; font-weight: 800; color: var(--text-dark); margin-bottom: 3px; }
.passport-region { font-size: 12px; color: var(--text-soft); margin-bottom: 12px; display: flex; align-items: center; gap: 4px; }

.status-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;
  margin-bottom: 12px;
}
.status-badge.good { background: rgba(18,133,106,0.12); color: var(--emerald); }
.status-badge.warn { background: rgba(212,134,10,0.12); color: var(--amber); }
.status-badge.bad  { background: rgba(193,59,42,0.12); color: var(--coral); }
.status-dot { width: 7px; height: 7px; border-radius: 50%; }
.status-dot.good { background: var(--emerald); }
.status-dot.warn { background: var(--amber); }
.status-dot.bad  { background: var(--coral); }

.param-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 12px 0; }
.param-card {
  background: rgba(13,79,140,0.05); border-radius: 10px;
  padding: 8px 10px; text-align: center;
  border: 1px solid rgba(13,79,140,0.1);
}
.param-card .p-name { font-size: 10px; color: var(--text-soft); font-weight: 600; letter-spacing: 0.04em; }
.param-card .p-value { font-size: 18px; font-weight: 800; color: var(--ocean); line-height: 1.2; }
.param-card .p-unit { font-size: 10px; color: var(--text-soft); }

.gauge-wrap { margin: 10px 0; }
.gauge-label { font-size: 11px; color: var(--text-soft); margin-bottom: 4px; display: flex; justify-content: space-between; }
.gauge-bar {
  height: 8px; border-radius: 4px;
  background: linear-gradient(to right, var(--coral) 0%, var(--amber) 30%, var(--emerald) 60%, var(--ocean) 100%);
  position: relative;
}
.gauge-indicator {
  position: absolute; top: -3px;
  width: 14px; height: 14px; border-radius: 50%;
  background: #fff; border: 2.5px solid var(--ocean);
  transform: translateX(-50%);
  box-shadow: 0 1px 4px rgba(0,0,0,0.2);
  transition: left .5s ease;
}
.gauge-scale { display: flex; justify-content: space-between; font-size: 9px; color: var(--text-soft); margin-top: 2px; }

.passport-researcher {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px; border-radius: 10px;
  background: rgba(26,111,181,0.06); border: 1px solid rgba(26,111,181,0.1);
  margin: 10px 0;
}
.researcher-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, var(--sky), var(--emerald));
  display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 700; color: #fff; flex-shrink: 0;
}
.researcher-info .r-name { font-size: 13px; font-weight: 700; color: var(--text-dark); }
.researcher-info .r-role { font-size: 11px; color: var(--text-soft); }

.passport-chart { margin: 10px 0; }
.passport-chart canvas { width: 100%; height: 120px; }


#bottom-drawer {
  position: absolute; bottom: 0; left: 300px; right: 314px;
  z-index: 50;
  background: var(--glass-bg);
  backdrop-filter: var(--blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--panel-radius) var(--panel-radius) 0 0;
  box-shadow: 0 -4px 32px rgba(13,35,80,0.15);
  transition: transform .4s cubic-bezier(.22,.87,.36,1);
  max-height: 55vh;
  display: flex; flex-direction: column;
}
#bottom-drawer.collapsed { transform: translateY(calc(100% - 46px)); }

.drawer-handle {
  padding: 10px 16px;
  display: flex; align-items: center; justify-content: space-between;
  cursor: pointer; border-bottom: 1px solid rgba(13,79,140,0.1);
  flex-shrink: 0;
}
.drawer-grip { width: 32px; height: 4px; border-radius: 2px; background: rgba(13,79,140,0.2); margin: 0 auto; }
.drawer-title { font-size: 13px; font-weight: 700; color: var(--text-dark); }
.drawer-actions { display: flex; gap: 8px; }

.search-input {
  width: 100%; padding: 7px 12px; border-radius: 10px;
  border: 1px solid rgba(13,79,140,0.15); background: rgba(255,255,255,0.9);
  font-size: 13px; outline: none; color: var(--text-dark);
  transition: border-color .2s;
}
.search-input:focus { border-color: var(--sky); }

.table-wrap { overflow-y: auto; flex: 1; }
.table-wrap::-webkit-scrollbar { width: 4px; }
.table-wrap::-webkit-scrollbar-thumb { background: rgba(13,79,140,0.15); border-radius: 2px; }

.registry-table {
  width: 100%; border-collapse: collapse; font-size: 12px;
}
.registry-table thead th {
  padding: 7px 10px; background: rgba(13,79,140,0.06);
  font-size: 11px; font-weight: 700; color: var(--text-soft);
  text-align: left; letter-spacing: 0.04em; position: sticky; top: 0; z-index: 2;
  border-bottom: 1px solid rgba(13,79,140,0.1);
}
.registry-table tbody tr {
  cursor: pointer; transition: background .15s;
  border-bottom: 1px solid rgba(13,79,140,0.06);
}
.registry-table tbody tr:nth-child(even) { background: var(--row-alt); }
.registry-table tbody tr:hover { background: rgba(26,111,181,0.08); }
.registry-table td { padding: 7px 10px; color: var(--text-mid); }
.registry-table td:first-child { color: var(--text-dark); font-weight: 600; }

.quality-tag {
  display: inline-block; padding: 2px 8px; border-radius: 8px;
  font-size: 10px; font-weight: 700;
}
.quality-tag.good { background: rgba(18,133,106,0.12); color: var(--emerald); }
.quality-tag.warn { background: rgba(212,134,10,0.12); color: var(--amber); }
.quality-tag.bad  { background: rgba(193,59,42,0.12); color: var(--coral); }


#add-form-overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(10,22,40,0.85);
  backdrop-filter: blur(6px);
  display: none; align-items: center; justify-content: center;
  padding: 20px;
  animation: fadeIn .25s ease;
}
#add-form-overlay.active { display: flex; }

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideUp { from { transform: translateY(30px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

.form-modal {
  background: #fff; border-radius: 22px;
  width: 100%; max-width: 480px; max-height: 92vh;
  overflow-y: auto; padding: 28px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  animation: slideUp .3s ease;
}
.form-modal::-webkit-scrollbar { width: 4px; }
.form-modal::-webkit-scrollbar-thumb { background: rgba(13,79,140,0.15); border-radius: 2px; }

.form-title { font-size: 20px; font-weight: 800; color: var(--text-dark); margin-bottom: 4px; }
.form-subtitle { font-size: 13px; color: var(--text-soft); margin-bottom: 22px; }

.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 12px; font-weight: 700; color: var(--text-mid); margin-bottom: 6px; letter-spacing: 0.03em; }
.form-group input, .form-group select, .form-group textarea {
  width: 100%; padding: 10px 14px; border-radius: 12px;
  border: 1.5px solid rgba(13,79,140,0.15); background: #fff;
  font-size: 14px; color: var(--text-dark); outline: none;
  font-family: inherit; transition: border-color .2s;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: var(--sky);
  box-shadow: 0 0 0 3px rgba(26,111,181,0.08);
}
.form-group textarea { min-height: 80px; resize: vertical; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

.geo-btn {
  width: 100%; padding: 10px; border-radius: 12px;
  background: rgba(26,111,181,0.07); border: 1.5px dashed rgba(26,111,181,0.25);
  color: var(--sky); font-size: 13px; font-weight: 600;
  cursor: pointer; transition: background .2s; font-family: inherit;
}
.geo-btn:hover { background: rgba(26,111,181,0.12); }

.form-actions { display: flex; gap: 10px; margin-top: 22px; }
.btn-submit {
  flex: 1; padding: 12px; border-radius: 14px;
  background: linear-gradient(135deg, var(--sky), var(--emerald));
  color: #fff; border: none; font-size: 15px; font-weight: 700;
  cursor: pointer; transition: opacity .2s, transform .15s;
  font-family: inherit;
}
.btn-submit:hover { opacity: .9; transform: translateY(-1px); }
.btn-cancel {
  padding: 12px 20px; border-radius: 14px;
  background: rgba(13,79,140,0.06); border: 1px solid rgba(13,79,140,0.12);
  color: var(--text-mid); font-size: 14px; cursor: pointer;
  font-family: inherit; transition: background .2s;
}
.btn-cancel:hover { background: rgba(13,79,140,0.1); }

#view-science {
  position: absolute; inset: 0; top: 58px;
  background: #f0f4f9;
  overflow-y: auto;
  padding: 28px;
  z-index: 80;
}

.science-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 24px;
}
.science-title { font-size: 26px; font-weight: 800; color: var(--text-dark); }
.science-subtitle { font-size: 14px; color: var(--text-soft); margin-top: 3px; }

.articles-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px; margin-bottom: 28px;
}

.article-card {
  background: #fff; border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(13,35,80,0.08);
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  border: 1px solid rgba(13,79,140,0.08);
}
.article-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(13,35,80,0.14); }

.article-cover {
  height: 150px;
  display: flex; align-items: center; justify-content: center;
  font-size: 52px;
  position: relative; overflow: hidden;
}
.article-cover-label {
  position: absolute; top: 10px; left: 10px;
  font-size: 10px; font-weight: 700; letter-spacing: 0.06em;
  padding: 3px 8px; border-radius: 8px; text-transform: uppercase;
}

.article-body { padding: 14px 16px; }
.article-tag {
  display: inline-block; font-size: 10px; font-weight: 700;
  padding: 3px 8px; border-radius: 8px; margin-bottom: 7px;
  letter-spacing: 0.04em;
}
.article-title { font-size: 15px; font-weight: 700; color: var(--text-dark); margin-bottom: 6px; line-height: 1.4; }
.article-excerpt { font-size: 12px; color: var(--text-soft); line-height: 1.6; margin-bottom: 10px; }
.article-meta {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 11px; color: var(--text-soft);
}
.article-author { display: flex; align-items: center; gap: 6px; }
.author-avatar {
  width: 24px; height: 24px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: #fff; flex-shrink: 0;
}

#article-modal-overlay {
  position: fixed; inset: 0; z-index: 300;
  background: rgba(10,22,40,0.88);
  backdrop-filter: blur(8px);
  display: none; align-items: center; justify-content: center;
  padding: 20px;
}
#article-modal-overlay.active { display: flex; }

.article-modal {
  background: #fff; border-radius: 22px;
  width: 100%; max-width: 700px; max-height: 92vh;
  overflow-y: auto;
  box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  animation: slideUp .3s ease;
}
.article-modal::-webkit-scrollbar { width: 5px; }
.article-modal::-webkit-scrollbar-thumb { background: rgba(13,79,140,0.15); border-radius: 3px; }

.article-modal-cover {
  height: 200px; display: flex; align-items: center; justify-content: center;
  font-size: 80px; border-radius: 22px 22px 0 0; overflow: hidden; position: relative;
}
.article-modal-close {
  position: absolute; top: 16px; right: 16px;
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(0,0,0,0.25); border: none;
  color: #fff; font-size: 18px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  transition: background .2s;
}
.article-modal-close:hover { background: rgba(0,0,0,0.4); }

.article-modal-body { padding: 28px; }
.article-modal-tag {
  display: inline-block; font-size: 11px; font-weight: 700;
  padding: 4px 10px; border-radius: 10px; margin-bottom: 10px;
}
.article-modal-title { font-size: 24px; font-weight: 800; color: var(--text-dark); margin-bottom: 10px; line-height: 1.35; }
.article-modal-meta { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid rgba(13,79,140,0.1); }
.article-modal-author { display: flex; align-items: center; gap: 8px; }
.article-modal-author-info .name { font-size: 13px; font-weight: 700; color: var(--text-dark); }
.article-modal-author-info .role { font-size: 11px; color: var(--text-soft); }
.article-modal-date { font-size: 12px; color: var(--text-soft); }

.article-modal-content { line-height: 1.75; color: var(--text-mid); }
.article-modal-content h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin: 20px 0 8px; }
.article-modal-content p { margin-bottom: 14px; font-size: 14px; }
.article-modal-content .highlight {
  background: rgba(26,111,181,0.07); border-left: 3px solid var(--sky);
  padding: 12px 16px; border-radius: 0 8px 8px 0; margin: 14px 0;
  font-size: 13px;
}
.article-modal-content .data-table { width: 100%; border-collapse: collapse; margin: 14px 0; font-size: 13px; }
.article-modal-content .data-table th { background: rgba(13,79,140,0.07); padding: 8px 12px; text-align: left; font-weight: 700; color: var(--text-dark); }
.article-modal-content .data-table td { padding: 7px 12px; border-bottom: 1px solid rgba(13,79,140,0.07); color: var(--text-mid); }


#publish-form-overlay {
  position: fixed; inset: 0; z-index: 350;
  background: rgba(10,22,40,0.9);
  backdrop-filter: blur(8px);
  display: none; align-items: center; justify-content: center;
  padding: 20px;
}
#publish-form-overlay.active { display: flex; }

.publish-modal {
  background: #fff; border-radius: 22px;
  width: 100%; max-width: 520px; max-height: 92vh;
  overflow-y: auto; padding: 30px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.4);
  animation: slideUp .3s ease;
}


.custom-popup .leaflet-popup-content-wrapper {
  background: var(--glass-bg) !important;
  backdrop-filter: blur(18px) !important;
  border-radius: 16px !important;
  box-shadow: var(--glass-shadow) !important;
  border: 1px solid var(--glass-border) !important;
  padding: 0 !important;
  overflow: hidden !important;
}
.custom-popup .leaflet-popup-content { margin: 0 !important; }
.custom-popup .leaflet-popup-tip { background: rgba(255,255,255,0.88) !important; }
.custom-popup .leaflet-popup-close-button { color: var(--text-soft) !important; right: 10px !important; top: 10px !important; font-size: 16px !important; }

.popup-inner { width: 240px; }
.popup-photo {
  width: 100%; height: 120px;
  display: flex; align-items: center; justify-content: center;
  font-size: 50px; border-radius: 16px 16px 0 0; overflow: hidden;
}
.popup-body { padding: 12px; }
.popup-name { font-size: 14px; font-weight: 800; color: var(--text-dark); margin-bottom: 3px; }
.popup-region { font-size: 11px; color: var(--text-soft); margin-bottom: 8px; }
.popup-ph-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.popup-ph-label { font-size: 11px; color: var(--text-soft); white-space: nowrap; }
.popup-ph-bar { flex: 1; height: 6px; border-radius: 3px; background: linear-gradient(to right, var(--coral), var(--amber), var(--emerald), var(--ocean)); position: relative; }
.popup-ph-thumb { position: absolute; top: -3px; width: 12px; height: 12px; border-radius: 50%; background: #fff; border: 2px solid var(--ocean); transform: translateX(-50%); }
.popup-ph-val { font-size: 11px; font-weight: 700; color: var(--ocean); white-space: nowrap; }
.popup-open-btn {
  width: 100%; padding: 8px; border-radius: 10px;
  background: linear-gradient(135deg, var(--sky), var(--emerald));
  color: #fff; border: none; font-size: 12px; font-weight: 700;
  cursor: pointer; transition: opacity .2s; font-family: inherit;
}
.popup-open-btn:hover { opacity: .88; }


.drop-marker {
  width: 28px; height: 36px;
  display: flex; align-items: flex-start; justify-content: center;
  position: relative;
}
.drop-svg { filter: drop-shadow(0 3px 6px rgba(0,0,0,0.35)); }


.marker-cluster-small, .marker-cluster-medium, .marker-cluster-large {
  background: rgba(26,111,181,0.2) !important;
}
.marker-cluster-small div, .marker-cluster-medium div, .marker-cluster-large div {
  background: rgba(26,111,181,0.75) !important;
  color: #fff !important; font-weight: 700 !important;
}

.drawer-search-row {
  padding: 8px 12px; border-bottom: 1px solid rgba(13,79,140,0.1);
  display: flex; gap: 8px; align-items: center; flex-shrink: 0;
}


.toast {
  position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg, #12856A, #1A6FB5);
  color: #fff; padding: 12px 22px; border-radius: 30px;
  font-size: 13px; font-weight: 600; z-index: 9999;
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  animation: toastIn .3s ease;
  white-space: nowrap;
}
@keyframes toastIn { from { opacity:0; transform: translateX(-50%) translateY(12px); } to { opacity:1; transform: translateX(-50%) translateY(0); } }


.upload-zone {
  border: 2px dashed rgba(26,111,181,0.25); border-radius: 12px;
  padding: 20px; text-align: center; cursor: pointer;
  background: rgba(26,111,181,0.03); transition: background .2s, border-color .2s;
}
.upload-zone:hover { background: rgba(26,111,181,0.07); border-color: rgba(26,111,181,0.4); }
.upload-zone p { font-size: 13px; color: var(--text-soft); }
.upload-zone strong { font-size: 14px; color: var(--sky); display: block; margin-bottom: 4px; }
.upload-zone input { display: none; }

.pdf-tag {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 10px; border-radius: 8px;
  background: rgba(193,59,42,0.1); color: var(--coral);
  font-size: 12px; font-weight: 600; margin-top: 8px;
}

/* Responsive */
@media (max-width: 768px) {
  #left-panel { width: 240px; }
  #right-panel { display: none; }
  #bottom-drawer { left: 254px; right: 0; }
  .header-stats { display: none; }
}
@media (max-width: 540px) {
  #left-panel { width: 220px; transform: translateX(-240px); }
  #left-panel.mobile-open { transform: translateX(0); }
  #bottom-drawer { left: 0; right: 0; }
}
</style>
</head>
<body>


<header id="header">
  <div class="logo">
    <div class="logo-mark">💧</div>
    <div class="logo-text">
      <strong>АК-БУЛАК</strong>
      <span>Водные ресурсы Казахстана</span>
    </div>
  </div>

  <nav class="nav-tabs">
    <button class="nav-tab active" onclick="switchView('map')">🗺 Карта</button>
    <button class="nav-tab" onclick="switchView('science')">🔬 Наука и статьи</button>
  </nav>

  <div class="header-stats" id="header-stats">
    <div class="hstat"><span class="hstat-dot good"></span><strong id="stat-total">0</strong>&nbsp;источников</div>
    <div class="hstat"><span class="hstat-dot good"></span><strong id="stat-good">0%</strong>&nbsp;питьевая</div>
    <div class="hstat"><span class="hstat-dot warn"></span><strong id="stat-warn">0</strong>&nbsp;тех.</div>
    <div class="hstat"><span class="hstat-dot bad"></span><strong id="stat-bad">0</strong>&nbsp;опасных</div>
  </div>

  <button class="btn-outline" onclick="openPublishForm()" style="margin-left:auto">📄 Опубликовать статью</button>
  <button class="btn-primary" onclick="openAddForm()">+ Добавить источник</button>
</header>


<div id="view-map">
  
  <div id="map"></div>

  <div id="left-panel">
    <div class="panel-header">
      <span class="panel-title">🔬 Аналитика</span>
      <span class="panel-badge" id="lp-badge">0 объектов</span>
    </div>
    <div class="panel-scroll">
      <!-- Stats -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="label">Проверено источников</div>
          <div class="value" id="lp-total">0</div>
          <div class="subtext">по всему Казахстану</div>
        </div>
        <div class="stat-card">
          <div class="label">Чистая вода, %</div>
          <div class="value" id="lp-pct">0%</div>
          <div class="subtext">питьевого качества</div>
        </div>
        <div class="stat-card">
          <div class="label">Средний pH</div>
          <div class="value" id="lp-avg-ph">—</div>
          <div class="subtext">по всем источникам</div>
        </div>
        <div class="stat-card">
          <div class="label">Исследователей</div>
          <div class="value" id="lp-researchers">0</div>
          <div class="subtext">студентов и учёных</div>
        </div>
      </div>

      <!-- Filters -->
      <div class="filter-section">
        <span class="filter-label">Регион</span>
        <select class="filter-select" id="filter-region" onchange="applyFilters()">
          <option value="">Все регионы</option>
        </select>
      </div>

      <div class="filter-section">
        <span class="filter-label">Качество воды</span>
        <div class="checkbox-group">
          <label class="check-item">
            <div class="check-dot" style="background:var(--emerald)"></div>
            <input type="checkbox" id="chk-good" checked onchange="applyFilters()">
            <span>Питьевая (чистая)</span>
          </label>
          <label class="check-item">
            <div class="check-dot" style="background:var(--amber)"></div>
            <input type="checkbox" id="chk-warn" checked onchange="applyFilters()">
            <span>Техническая</span>
          </label>
          <label class="check-item">
            <div class="check-dot" style="background:var(--coral)"></div>
            <input type="checkbox" id="chk-bad" checked onchange="applyFilters()">
            <span>Опасная</span>
          </label>
        </div>
      </div>

      <div class="filter-section">
        <span class="filter-label">pH — минимум</span>
        <div class="slider-row">
          <span style="font-size:11px;color:var(--text-soft)">0</span>
          <input type="range" min="0" max="14" step="0.1" value="0" id="ph-min" oninput="document.getElementById('ph-min-val').textContent=this.value;applyFilters()">
          <span class="slider-val" id="ph-min-val">0</span>
        </div>
      </div>

      <div class="filter-section">
        <span class="filter-label">pH — максимум</span>
        <div class="slider-row">
          <span style="font-size:11px;color:var(--text-soft)">14</span>
          <input type="range" min="0" max="14" step="0.1" value="14" id="ph-max" oninput="document.getElementById('ph-max-val').textContent=this.value;applyFilters()">
          <span class="slider-val" id="ph-max-val">14</span>
        </div>
      </div>

      <div class="filter-section">
        <span class="filter-label">Жёсткость воды</span>
        <div class="slider-row">
          <span style="font-size:11px;color:var(--text-soft)">0</span>
          <input type="range" min="0" max="30" step="0.5" value="30" id="hard-max" oninput="document.getElementById('hard-max-val').textContent=this.value;applyFilters()">
          <span class="slider-val" id="hard-max-val">30</span>
          <span style="font-size:10px;color:var(--text-soft)">°Ж</span>
        </div>
      </div>

      <button onclick="resetFilters()" style="width:100%;padding:8px;border-radius:10px;border:1px solid rgba(13,79,140,0.15);background:rgba(13,79,140,0.04);color:var(--text-soft);font-size:12px;cursor:pointer;margin-top:4px;font-family:inherit">⟳ Сбросить фильтры</button>
    </div>
  </div>

  <!-- Right Panel (Passport) -->
  <div id="right-panel">
    <div class="panel-header">
      <span class="panel-title">📋 Паспорт источника</span>
    </div>
    <div id="passport-empty" class="passport-empty">
      <div class="icon">💧</div>
      <p>Нажмите на маркер родника на карте, чтобы просмотреть подробный паспорт источника</p>
    </div>
    <div id="passport-content" class="passport-content" style="display:none">
      <div id="pp-photo-wrap"></div>
      <div class="passport-body">
        <div class="passport-name" id="pp-name"></div>
        <div class="passport-region" id="pp-region"></div>
        <div id="pp-status"></div>

        <div class="param-grid">
          <div class="param-card">
            <div class="p-name">pH</div>
            <div class="p-value" id="pp-ph"></div>
            <div class="p-unit">ед.</div>
          </div>
          <div class="param-card">
            <div class="p-name">Жёсткость</div>
            <div class="p-value" id="pp-hard"></div>
            <div class="p-unit">°Ж</div>
          </div>
          <div class="param-card">
            <div class="p-name">Минерализация</div>
            <div class="p-value" id="pp-mineral"></div>
            <div class="p-unit">мг/л</div>
          </div>
          <div class="param-card">
            <div class="p-name">Расход</div>
            <div class="p-value" id="pp-flow"></div>
            <div class="p-unit">л/с</div>
          </div>
        </div>

       
        <div class="gauge-wrap">
          <div class="gauge-label">
            <span>pH уровень</span>
            <span id="pp-ph-label">—</span>
          </div>
          <div class="gauge-bar">
            <div class="gauge-indicator" id="ph-gauge-thumb" style="left:50%"></div>
          </div>
          <div class="gauge-scale"><span>0</span><span>3.5</span><span>7</span><span>10.5</span><span>14</span></div>
        </div>

        <!-- Researcher -->
        <div id="pp-researcher" class="passport-researcher"></div>

        <!-- Mini chart -->
        <div class="passport-chart">
          <span class="filter-label" style="margin-bottom:8px;display:block">Параметры (норма)</span>
          <canvas id="passport-chart-canvas" height="100"></canvas>
        </div>

        <div id="pp-description" style="font-size:12px;color:var(--text-soft);line-height:1.6;margin-top:8px;padding:10px;background:rgba(13,79,140,0.04);border-radius:10px;border:1px solid rgba(13,79,140,0.08)"></div>
      </div>
    </div>
  </div>


  <div id="bottom-drawer" class="collapsed">
    <div class="drawer-handle" onclick="toggleDrawer()">
      <span class="drawer-title">📊 Реестр источников</span>
      <div class="drawer-grip"></div>
      <div class="drawer-actions">
        <button onclick="event.stopPropagation();exportCSV()" class="btn-outline" style="font-size:11px;padding:4px 10px;color:var(--text-soft);border-color:rgba(13,79,140,0.2)">↓ CSV</button>
      </div>
    </div>
    <div class="drawer-search-row">
      <input type="text" class="search-input" id="table-search" placeholder="🔍 Поиск по названию, региону, статусу..." oninput="filterTable()">
    </div>
    <div class="table-wrap">
      <table class="registry-table">
        <thead>
          <tr>
            <th>Название</th>
            <th>Регион</th>
            <th>Статус</th>
            <th>pH</th>
            <th>Жёсткость</th>
            <th>Исследователь</th>
            <th>Координаты</th>
          </tr>
        </thead>
        <tbody id="table-body"></tbody>
      </table>
    </div>
  </div>
</div>

<div id="view-science">
  <div class="science-header">
    <div>
      <div class="science-title">🔬 Научно-исследовательский хаб</div>
      <div class="science-subtitle">Публикации, экспедиции и стандарты качества воды Казахстана</div>
    </div>
    <button class="btn-primary" onclick="openPublishForm()">+ Опубликовать работу</button>
  </div>

  <!-- Category tabs -->
  <div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap" id="article-tabs">
    <button class="nav-tab active" onclick="filterArticles('')" style="background:rgba(26,111,181,0.1);color:var(--ocean);border-radius:20px;padding:7px 16px;border:1px solid rgba(26,111,181,0.2);font-size:13px;cursor:pointer;font-weight:600">Все работы</button>
    <button class="nav-tab" onclick="filterArticles('Исследование')" style="border-radius:20px;padding:7px 16px;border:1px solid rgba(13,79,140,0.15);font-size:13px;cursor:pointer">🧪 Исследования</button>
    <button class="nav-tab" onclick="filterArticles('Экспедиция')" style="border-radius:20px;padding:7px 16px;border:1px solid rgba(13,79,140,0.15);font-size:13px;cursor:pointer">🏔 Экспедиции</button>
    <button class="nav-tab" onclick="filterArticles('Стандарт')" style="border-radius:20px;padding:7px 16px;border:1px solid rgba(13,79,140,0.15);font-size:13px;cursor:pointer">📋 Стандарты</button>
    <button class="nav-tab" onclick="filterArticles('Студенческий проект')" style="border-radius:20px;padding:7px 16px;border:1px solid rgba(13,79,140,0.15);font-size:13px;cursor:pointer">🎓 Студенческие</button>
  </div>

  <div class="articles-grid" id="articles-grid"></div>
</div>

<div id="add-form-overlay">
  <div class="form-modal">
    <div class="form-title">💧 Новый источник</div>
    <div class="form-subtitle">Зарегистрируйте родник или скважину в базе данных</div>

    <div class="form-group">
      <label>Название источника *</label>
      <input type="text" id="f-name" placeholder="напр. Родник «Ак-Булак»">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Регион *</label>
        <select id="f-region">
          <option value="">Выберите...</option>
          <option>Алматинская</option>
          <option>Астана (г.)</option>
          <option>Алматы (г.)</option>
          <option>Жамбылская</option>
          <option>Туркестанская</option>
          <option>Шымкент (г.)</option>
          <option>Акмолинская</option>
          <option>Актюбинская</option>
          <option>Атырауская</option>
          <option>ВКО</option>
          <option>Жетысуская</option>
          <option>ЗКО</option>
          <option>Карагандинская</option>
          <option>Костанайская</option>
          <option>Кызылординская</option>
          <option>Мангистауская</option>
          <option>Павлодарская</option>
          <option>СКО</option>
          <option>Улытауская</option>
          <option>Абайская</option>
        </select>
      </div>
      <div class="form-group">
        <label>Статус воды *</label>
        <select id="f-status">
          <option value="good">✅ Питьевая</option>
          <option value="warn">⚠️ Техническая</option>
          <option value="bad">🚫 Опасная</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>Геопозиция (широта, долгота) *</label>
      <div style="display:flex;gap:8px;align-items:center">
        <input type="number" id="f-lat" placeholder="напр. 43.2565" step="0.0001" style="flex:1">
        <input type="number" id="f-lng" placeholder="напр. 76.9286" step="0.0001" style="flex:1">
        <button class="geo-btn" style="width:auto;padding:10px 14px;white-space:nowrap" onclick="getGeo()">📍 GPS</button>
      </div>
    </div>

    <div class="form-row3">
      <div class="form-group">
        <label>pH</label>
        <input type="number" id="f-ph" placeholder="7.0" min="0" max="14" step="0.1">
      </div>
      <div class="form-group">
        <label>Жёсткость, °Ж</label>
        <input type="number" id="f-hard" placeholder="5.0" min="0" max="30" step="0.1">
      </div>
      <div class="form-group">
        <label>Минерализация</label>
        <input type="number" id="f-mineral" placeholder="350" min="0">
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Расход, л/с</label>
        <input type="number" id="f-flow" placeholder="1.5" min="0" step="0.1">
      </div>
      <div class="form-group">
        <label>Имя исследователя</label>
        <input type="text" id="f-researcher" placeholder="Ф. И. О.">
      </div>
    </div>

    <div class="form-group">
      <label>Описание / заметки</label>
      <textarea id="f-desc" placeholder="Характеристики источника, особенности, история..."></textarea>
    </div>

    <div class="form-actions">
      <button class="btn-cancel" onclick="closeAddForm()">Отмена</button>
      <button class="btn-submit" onclick="submitSpring()">💾 Добавить в реестр</button>
    </div>
  </div>
</div>

<!-- ─── ARTICLE FULL-PAGE MODAL ─── -->
<div id="article-modal-overlay" onclick="if(event.target===this)closeArticleModal()">
  <div class="article-modal">
    <div class="article-modal-cover" id="am-cover"></div>
    <div class="article-modal-body">
      <div class="article-modal-tag" id="am-tag"></div>
      <div class="article-modal-title" id="am-title"></div>
      <div class="article-modal-meta">
        <div class="article-modal-author">
          <div class="author-avatar" id="am-avatar" style="width:40px;height:40px;font-size:14px;font-weight:700;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;"></div>
          <div class="article-modal-author-info">
            <div class="name" id="am-author-name"></div>
            <div class="role" id="am-author-role"></div>
          </div>
        </div>
        <div class="article-modal-date" id="am-date"></div>
        <div id="am-pdf-link"></div>
      </div>
      <div class="article-modal-content" id="am-content"></div>
    </div>
  </div>
</div>

<div id="publish-form-overlay" onclick="if(event.target===this)closePublishForm()">
  <div class="publish-modal">
