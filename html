    <circle cx="14" cy="14" r="5" fill="rgba(255,255,255,0.4)"/>
  </svg>`;
  return L.divIcon({
    html: svg,
    className: '', iconSize: [28,38], iconAnchor: [14,38], popupAnchor: [0,-40]
  });
}

const STATUS_COLORS = { good:'#12856A', warn:'#D4860A', bad:'#C13B2A' };

function renderMarkers() {
  clusterGroup.clearLayers();
  allMarkers = {};
  springs.forEach(s => {
    const icon = makeDropIcon(STATUS_COLORS[s.status]);
    const marker = L.marker([s.lat, s.lng], { icon });
    marker.bindPopup(makePopupHTML(s), { className:'custom-popup', maxWidth:260 });
    marker.on('click', () => openPassport(s.id));
    clusterGroup.addLayer(marker);
    allMarkers[s.id] = marker;
  });
}

function makePopupHTML(s) {
  const colorMap = { good:'#d4f5ea', warn:'#fff4d9', bad:'#fce8e6' };
  const phPct = (s.ph / 14 * 100).toFixed(1);
  return `<div class="popup-inner">
    <div class="popup-photo" style="background:${colorMap[s.status]}">
      <span style="font-size:52px">💧</span>
    </div>
    <div class="popup-body">
      <div class="popup-name">${s.name}</div>
      <div class="popup-region">📍 ${s.region}</div>
      <div class="popup-ph-row">
        <span class="popup-ph-label">pH ${s.ph}</span>
        <div class="popup-ph-bar"><div class="popup-ph-thumb" style="left:${phPct}%"></div></div>
        <span class="popup-ph-val">${STATUS_LABELS[s.status]}</span>
      </div>
      <button class="popup-open-btn" onclick="openPassport('${s.id}')">📋 Открыть паспорт</button>
    </div>
  </div>`;
}


function openPassport(id) {
  const s = springs.find(x => x.id === id);
  if (!s) return;

  document.getElementById('passport-empty').style.display = 'none';
  document.getElementById('passport-content').style.display = 'block';

  
  const coverColors = { good:'linear-gradient(135deg,#d4f5ea 0%,#9ee4ce 100%)', warn:'linear-gradient(135deg,#fff4d9 0%,#fcd888 100%)', bad:'linear-gradient(135deg,#fce8e6 0%,#f9b2aa 100%)' };
  document.getElementById('pp-photo-wrap').innerHTML = `
    <div class="passport-photo" style="background:${coverColors[s.status]}">
      <span style="font-size:56px">💧</span>
    </div>`;

  document.getElementById('pp-name').textContent = s.name;
  document.getElementById('pp-region').innerHTML = `📍 ${s.region} &nbsp;·&nbsp; ${s.lat.toFixed(4)}, ${s.lng.toFixed(4)}`;

  const statusHTM = { good:'<span class="status-badge good"><span class="status-dot good"></span>Питьевая</span>', warn:'<span class="status-badge warn"><span class="status-dot warn"></span>Техническая</span>', bad:'<span class="status-badge bad"><span class="status-dot bad"></span>Опасная</span>' };
  document.getElementById('pp-status').innerHTML = statusHTM[s.status];

  document.getElementById('pp-ph').textContent = s.ph;
  document.getElementById('pp-hard').textContent = s.hard;
  document.getElementById('pp-mineral').textContent = s.mineral;
  document.getElementById('pp-flow').textContent = s.flow;

  const phPct = (s.ph / 14 * 100).toFixed(1);
  document.getElementById('ph-gauge-thumb').style.left = phPct + '%';
  const phLabel = s.ph < 6.5 ? '⚠️ Кислая' : s.ph > 8.5 ? '⚠️ Щелочная' : '✅ Нейтральная';
  document.getElementById('pp-ph-label').textContent = `pH ${s.ph} — ${phLabel}`;

  const initials = s.researcher.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  const avatarColor = AVATAR_COLORS[Math.abs(s.id.charCodeAt(1)) % AVATAR_COLORS.length];
  document.getElementById('pp-researcher').innerHTML = `
    <div class="researcher-avatar" style="background:${avatarColor}">${initials}</div>
    <div class="researcher-info">
      <div class="r-name">${s.researcher}</div>
      <div class="r-role">🎓 Исследователь · КазНУ</div>
    </div>`;

  
  if (passportChart) passportChart.destroy();
  const ctx = document.getElementById('passport-chart-canvas').getContext('2d');
  const normPh = Math.min(s.ph / 8.5, 1);
  const normHard = Math.min(s.hard / 7, 1);
  const normMin = Math.min(s.mineral / 1000, 1);
  const normFlow = Math.min(s.flow / 10, 1);
  passportChart = new Chart(ctx, {
    type: 'radar',
    data: {
      labels: ['pH', 'Жёсткость', 'Минерализация', 'Расход', 'Чистота'],
      datasets: [{
        data: [normPh*100, normHard*100, normMin*100, normFlow*100, s.status==='good'?90:s.status==='warn'?55:20],
        backgroundColor: 'rgba(26,111,181,0.15)',
        borderColor: 'rgba(26,111,181,0.7)',
        borderWidth: 1.5,
        pointBackgroundColor: '#1A6FB5',
        pointRadius: 3
      }]
    },
    options: { responsive:true, maintainAspectRatio:false, scales:{ r:{ min:0, max:100, grid:{color:'rgba(13,79,140,0.1)'}, ticks:{display:false}, pointLabels:{font:{size:10},color:'#6B7E9A'} } }, plugins:{legend:{display:false}} }
  });

  document.getElementById('pp-description').textContent = s.desc;


  map.flyTo([s.lat, s.lng], 11, { duration: 1.2 });
}


function populateRegionFilter() {
  const sel = document.getElementById('filter-region');
  const regions = [...new Set(springs.map(s=>s.region))].sort();
  regions.forEach(r => {
    const opt = document.createElement('option');
    opt.value = r; opt.textContent = r;
    sel.appendChild(opt);
  });
}

function applyFilters() {
  currentFilter.region = document.getElementById('filter-region').value;
  currentFilter.good = document.getElementById('chk-good').checked;
  currentFilter.warn = document.getElementById('chk-warn').checked;
  currentFilter.bad = document.getElementById('chk-bad').checked;
  currentFilter.phMin = parseFloat(document.getElementById('ph-min').value);
  currentFilter.phMax = parseFloat(document.getElementById('ph-max').value);
  currentFilter.hardMax = parseFloat(document.getElementById('hard-max').value);

  clusterGroup.clearLayers();
  const filtered = springs.filter(s => {
    if (currentFilter.region && s.region !== currentFilter.region) return false;
    if (!currentFilter[s.status]) return false;
    if (s.ph < currentFilter.phMin || s.ph > currentFilter.phMax) return false;
    if (s.hard > currentFilter.hardMax) return false;
    return true;
  });
  filtered.forEach(s => clusterGroup.addLayer(allMarkers[s.id]));
  document.getElementById('lp-badge').textContent = filtered.length + ' объектов';
  renderTable(filtered);
}

function resetFilters() {
  document.getElementById('filter-region').value = '';
  document.getElementById('chk-good').checked = true;
  document.getElementById('chk-warn').checked = true;
  document.getElementById('chk-bad').checked = true;
  document.getElementById('ph-min').value = 0;
  document.getElementById('ph-max').value = 14;
  document.getElementById('hard-max').value = 30;
  document.getElementById('ph-min-val').textContent = '0';
  document.getElementById('ph-max-val').textContent = '14';
  document.getElementById('hard-max-val').textContent = '30';
  applyFilters();
  springs.forEach(s => clusterGroup.addLayer(allMarkers[s.id]));
  document.getElementById('lp-badge').textContent = springs.length + ' объектов';
  renderTable();
}


function updateStats() {
  const total = springs.length;
  const good = springs.filter(s=>s.status==='good').length;
  const warn = springs.filter(s=>s.status==='warn').length;
  const bad = springs.filter(s=>s.status==='bad').length;
  const pct = total ? Math.round(good/total*100) : 0;
  const avgPh = total ? (springs.reduce((a,s)=>a+s.ph,0)/total).toFixed(1) : '—';
  const researchers = [...new Set(springs.map(s=>s.researcher).filter(Boolean))].length;

  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-good').textContent = pct + '%';
  document.getElementById('stat-warn').textContent = warn;
  document.getElementById('stat-bad').textContent = bad;
  document.getElementById('lp-total').textContent = total;
  document.getElementById('lp-pct').textContent = pct + '%';
  document.getElementById('lp-avg-ph').textContent = avgPh;
  document.getElementById('lp-researchers').textContent = researchers;
  document.getElementById('lp-badge').textContent = total + ' объектов';
}


function renderTable(data) {
  const list = data || springs;
  const tbody = document.getElementById('table-body');
  tbody.innerHTML = list.map(s => `
    <tr onclick="openPassport('${s.id}')">
      <td>${s.name}</td>
      <td>${s.region}</td>
      <td><span class="quality-tag ${s.status}">${STATUS_LABELS[s.status]}</span></td>
      <td>${s.ph}</td>
      <td>${s.hard}°Ж</td>
      <td>${s.researcher}</td>
      <td style="font-size:11px;color:var(--text-soft)">${s.lat.toFixed(3)}, ${s.lng.toFixed(3)}</td>
    </tr>`).join('');
}

function filterTable() {
  const q = document.getElementById('table-search').value.toLowerCase();
  const filtered = springs.filter(s =>
    s.name.toLowerCase().includes(q) ||
    s.region.toLowerCase().includes(q) ||
    STATUS_LABELS[s.status].toLowerCase().includes(q) ||
    s.researcher.toLowerCase().includes(q)
  );
  renderTable(filtered);
  // Also filter markers
  clusterGroup.clearLayers();
  filtered.forEach(s => clusterGroup.addLayer(allMarkers[s.id]));
}

function toggleDrawer() {
  document.getElementById('bottom-drawer').classList.toggle('collapsed');
}

function exportCSV() {
  const rows = [['Название','Регион','Статус','pH','Жёсткость','Минерализация','Расход','Исследователь','Широта','Долгота','Описание']];
  springs.forEach(s => rows.push([s.name,s.region,STATUS_LABELS[s.status],s.ph,s.hard,s.mineral,s.flow,s.researcher,s.lat,s.lng,s.desc||'']));
  const csv = rows.map(r => r.map(c=>`"${c}"`).join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,\uFEFF'+encodeURIComponent(csv);
  a.download = 'ak_bulak_springs.csv';
  a.click();
  showToast('✅ CSV-файл скачан');
}

function openAddForm() { document.getElementById('add-form-overlay').classList.add('active'); }
function closeAddForm() { document.getElementById('add-form-overlay').classList.remove('active'); }

function getGeo() {
  if (!navigator.geolocation) { showToast('⚠️ Геолокация недоступна'); return; }
  navigator.geolocation.getCurrentPosition(pos => {
    document.getElementById('f-lat').value = pos.coords.latitude.toFixed(6);
    document.getElementById('f-lng').value = pos.coords.longitude.toFixed(6);
    showToast('📍 Координаты получены');
  }, () => showToast('⚠️ Не удалось получить координаты'));
}

function submitSpring() {
  const name = document.getElementById('f-name').value.trim();
  const region = document.getElementById('f-region').value;
  const lat = parseFloat(document.getElementById('f-lat').value);
  const lng = parseFloat(document.getElementById('f-lng').value);
  const status = document.getElementById('f-status').value;
  const ph = parseFloat(document.getElementById('f-ph').value) || 7.0;
  const hard = parseFloat(document.getElementById('f-hard').value) || 5.0;
  const mineral = parseFloat(document.getElementById('f-mineral').value) || 300;
  const flow = parseFloat(document.getElementById('f-flow').value) || 1.0;
  const researcher = document.getElementById('f-researcher').value.trim() || 'Аноним';
  const desc = document.getElementById('f-desc').value.trim();

  if (!name || !region || isNaN(lat) || isNaN(lng)) {
    showToast('⚠️ Заполните обязательные поля');
    return;
  }

  const id = 's' + Date.now();
  const s = { id, name, region, lat, lng, status, ph, hard, mineral, flow, researcher, desc };
  springs.push(s);
  saveState();

  // Add marker
  const icon = makeDropIcon(STATUS_COLORS[status]);
  const marker = L.marker([lat, lng], { icon });
  marker.bindPopup(makePopupHTML(s), { className:'custom-popup', maxWidth:260 });
  marker.on('click', () => openPassport(id));
  clusterGroup.addLayer(marker);
  allMarkers[id] = marker;


  const sel = document.getElementById('filter-region');
  if (![...sel.options].some(o=>o.value===region)) {
    const opt = document.createElement('option');
    opt.value = region; opt.textContent = region;
    sel.appendChild(opt);
  }

  updateStats();
  renderTable();
  closeAddForm();
  map.flyTo([lat, lng], 12);
  showToast('✅ Источник добавлен в реестр!');

  // Clear form
  ['f-name','f-lat','f-lng','f-ph','f-hard','f-mineral','f-flow','f-researcher','f-desc'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  document.getElementById('f-region').value = '';
}


function switchView(v) {
  document.getElementById('view-map').style.display = v==='map' ? 'block' : 'none';
  document.getElementById('view-science').style.display = v==='science' ? 'block' : 'none';
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  event.target.classList.add('active');
  if (v==='science') renderArticles();
}

function renderArticles(filter) {
  const f = filter !== undefined ? filter : currentArticleFilter;
  currentArticleFilter = f;
  const list = f ? articles.filter(a=>a.tag===f) : articles;
  const grid = document.getElementById('articles-grid');
  grid.innerHTML = list.map(a => {
    const tc = TAG_COLORS[a.tag] || TAG_COLORS['Исследование'];
    const bg = COVER_BG[a.tag] || COVER_BG['Исследование'];
    const initials = a.author.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
    const avatarColor = AVATAR_COLORS[Math.abs((a.id||'x').charCodeAt(1)||0) % AVATAR_COLORS.length];
    return `<div class="article-card" onclick="openArticle('${a.id}')">
      <div class="article-cover" style="background:${bg}">
        <span>${a.emoji || COVER_ICONS[a.tag] || '📄'}</span>
        <div class="article-cover-label" style="background:${tc.bg};color:${tc.color}">${a.tag}</div>
      </div>
      <div class="article-body">
        <span class="article-tag" style="background:${tc.bg};color:${tc.color}">${a.tag}</span>
        <div class="article-title">${a.title}</div>
        <div class="article-excerpt">${a.excerpt}</div>
        <div class="article-meta">
          <div class="article-author">
            <div class="author-avatar" style="background:${avatarColor}">${initials}</div>
            <span>${a.author}</span>
          </div>
          <span>${a.date || ''}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

function filterArticles(tag) {
  currentArticleFilter = tag;
  document.querySelectorAll('#article-tabs button').forEach(b => {
    b.style.background = ''; b.style.color = ''; b.style.borderColor = '';
  });
  event.target.style.background = 'rgba(26,111,181,0.1)';
  event.target.style.color = 'var(--ocean)';
  event.target.style.borderColor = 'rgba(26,111,181,0.2)';
  renderArticles(tag);
}

function openArticle(id) {
  const a = articles.find(x=>x.id===id);
  if (!a) return;
  const tc = TAG_COLORS[a.tag] || TAG_COLORS['Исследование'];
  const bg = COVER_BG[a.tag] || COVER_BG['Исследование'];
  const initials = a.author.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  const avatarColor = AVATAR_COLORS[Math.abs((a.id||'x').charCodeAt(1)||0) % AVATAR_COLORS.length];

  document.getElementById('am-cover').innerHTML = `
    <div style="width:100%;height:100%;background:${bg};display:flex;align-items:center;justify-content:center;font-size:80px">${a.emoji||'📄'}</div>
    <button class="article-modal-close" onclick="closeArticleModal()">✕</button>`;
  document.getElementById('am-tag').innerHTML = `<span style="background:${tc.bg};color:${tc.color};padding:4px 10px;border-radius:10px;font-size:11px;font-weight:700">${a.tag}</span>`;
  document.getElementById('am-title').textContent = a.title;
  document.getElementById('am-avatar').style.background = avatarColor;
  document.getElementById('am-avatar').textContent = initials;
  document.getElementById('am-author-name').textContent = a.author;
  document.getElementById('am-author-role').textContent = a.org || '';
  document.getElementById('am-date').textContent = a.date || '';
  document.getElementById('am-content').innerHTML = a.body || '';
  if (a.pdfName) {
    document.getElementById('am-pdf-link').innerHTML = `<span class="pdf-tag">📄 ${a.pdfName}</span>`;
  } else {
    document.getElementById('am-pdf-link').innerHTML = '';
  }
  document.getElementById('article-modal-overlay').classList.add('active');
}

function closeArticleModal() {
  document.getElementById('article-modal-overlay').classList.remove('active');
}

function openPublishForm() { document.getElementById('publish-form-overlay').classList.add('active'); }
function closePublishForm() { document.getElementById('publish-form-overlay').classList.remove('active'); }

function handlePDFUpload(input) {
  if (input.files[0]) {
    selectedPDFName = input.files[0].name;
    document.getElementById('pdf-name-tag').innerHTML = `<span class="pdf-tag">📄 ${selectedPDFName}</span>`;
  }
}

function submitArticle() {
  const title = document.getElementById('pub-title').value.trim();
  const author = document.getElementById('pub-author').value.trim();
  const excerpt = document.getElementById('pub-excerpt').value.trim();
  const body = document.getElementById('pub-body').value.trim();
  const tag = document.getElementById('pub-category').value;
  const org = document.getElementById('pub-org').value.trim();

  if (!title || !author || !excerpt || !body) {
    showToast('⚠️ Заполните обязательные поля');
    return;
  }

  const id = 'a' + Date.now();
  const formattedBody = body.split('\n\n').map(p=>`<p>${p}</p>`).join('');
  const article = {
    id, tag,
    emoji: COVER_ICONS[tag] || '📄',
    title, excerpt,
    body: formattedBody,
    author, org,
    date: new Date().toLocaleDateString('ru-RU', {day:'numeric', month:'long', year:'numeric'}),
    pdfName: selectedPDFName || ''
  };
  articles.unshift(article);
  saveState();
  selectedPDFName = '';
  document.getElementById('pdf-name-tag').innerHTML = '';

  closePublishForm();
  renderArticles();
  showToast('🚀 Статья опубликована!');

  ['pub-title','pub-author','pub-org','pub-excerpt','pub-body'].forEach(i => document.getElementById(i).value = '');
  document.getElementById('pub-pdf-input').value = '';
}

function showToast(msg) {
  const t = document.createElement('div');
  t.className = 'toast'; t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity .4s'; setTimeout(()=>t.remove(),400); }, 2800);
}


window.addEventListener('DOMContentLoaded', () => {
  initMap();
  renderArticles();
});
</script>
</body>
